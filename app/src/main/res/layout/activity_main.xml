<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/header_bg"
            android:padding="20dp"
            android:layout_marginBottom="24dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎓"
                android:textSize="36sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GestionEtudiants"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#FFE4EF" />
        </LinearLayout>

        <!-- Card Ajouter -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="➕  Ajouter un étudiant"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#C2185B"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nom"
                android:textSize="13sp"
                android:textColor="#888888" />

            <EditText
                android:id="@+id/nom"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="4dp"
                android:hint="ex: AIT ZIDAN"
                android:textColor="#333333"
                android:textColorHint="#BBBBBB" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prénom"
                android:textSize="13sp"
                android:textColor="#888888" />

            <EditText
                android:id="@+id/prenom"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="14dp"
                android:layout_marginTop="4dp"
                android:hint="ex: Salma"
                android:textColor="#333333"
                android:textColorHint="#BBBBBB" />

            <Button
                android:id="@+id/bn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/button_primary"
                android:text="Valider"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Card Chercher / Supprimer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍  Chercher / Supprimer"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#C2185B"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID Étudiant"
                android:textSize="13sp"
                android:textColor="#888888" />

            <EditText
                android:id="@+id/id"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="12dp"
                android:layout_marginTop="4dp"
                android:hint="ex: 1"
                android:inputType="numberSigned"
                android:textColor="#333333"
                android:textColorHint="#BBBBBB" />

            <!-- Result box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/result_bg"
                android:padding="12dp"
                android:layout_marginBottom="14dp"
                android:minHeight="44dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/res"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="#AD1457"
                    android:textStyle="bold"
                    android:hint="Résultat ici…"
                    android:textColorHint="#E8A0B4" />
            </LinearLayout>

            <!-- Buttons row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/load"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/button_secondary"
                    android:text="Chercher"
                    android:textColor="#C2185B"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/delete"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/button_danger"
                    android:text="Supprimer"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
